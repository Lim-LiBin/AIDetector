<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#1E1838"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_inquiry_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/tv_inquiry_status"
        android:layout_marginEnd="12dp"
        android:text="문의 제목"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tv_inquiry_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_inquiry_title"
        android:layout_marginTop="6dp"
        android:text="2026. 05. 06"
        android:textColor="#888888"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_inquiry_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="접수 완료"
        android:textSize="12sp"
        android:textStyle="bold" />
</RelativeLayout>